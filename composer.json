{
    "name": "petalphp/microlyte",
    "type": "project",
    "description": "The PetalPHP Microlyte Framework built on top of Slim",
    "keywords": [
        "microframework",
        "rest",
        "router",
        "psr7"
    ],
    "homepage": "http://github.com/petalphp/microlyte",
    "license": "MIT",
    "authors": [
        {
            "name": "Josephp Asamoah",
            "email": "asamoahjoseph@gmail.com",
            "homepage": "http://github.com/jobasco"
        }
    ],
    "require": {
        "php": "^7.4 || ^8.2",
        "ext-json": "*",
        "petalphp/microlyte-framework": "^1.0.0"
    },
    "require-dev": {
        "jangregor/phpstan-prophecy": "^1.0.2",
        "phpspec/prophecy-phpunit": "^2.2.0",
        "phpstan/extension-installer": "^1.4.1",
        "phpstan/phpstan": "^1.11.9",
        "phpunit/phpunit": "^9.6.20",
        "squizlabs/php_codesniffer": "^3.10.2"
    },
    "config": {
        "allow-plugins": {
            "phpstan/extension-installer": true
        },
        "process-timeout": 0,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "start": "php -S localhost:8080 -t public",
        "test": "phpunit",
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    }
}
